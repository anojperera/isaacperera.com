---
const currentYear = new Date().getFullYear();

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class={`${noMarginTop ? "" : "mt-auto"}`}>
  <div class="mx-auto max-w-3xl px-4">
    <div class="footer-line"></div>
    <div class="footer-wrapper py-6">
      <div
        class="copyright-wrapper font-mono text-xs tracking-wide text-[color:var(--ink-soft)]"
      >
        <span>◇ © {currentYear} Isaac Perera · end of transmission</span>
      </div>
    </div>
  </div>
</footer>

<style>
  @reference "tailwindcss";
  footer {
    @apply w-full;
  }
  .footer-line {
    @apply h-px w-full;
    background: linear-gradient(
      to right,
      transparent,
      var(--panel-border),
      transparent
    );
  }
  .footer-wrapper {
    @apply flex flex-col items-center justify-center gap-y-3 py-2 text-center sm:py-5;
  }
</style>
