---
import LinkButton from "./LinkButton.astro";

export interface Props {
  activeNav?: "posts" | "tags" | "about" | "search";
}

const { activeNav } = Astro.props;
---

<header class="sticky top-0 z-50">
  <a id="skip-to-content" href="#main-content">Skip to content</a>
  <div
    class="header-bar mx-auto mt-3 flex max-w-3xl items-center justify-between rounded-2xl border px-4 py-3 sm:mx-auto"
  >
    <!-- Logo / callsign -->
    <a
      href="/"
      class="logo group flex items-center gap-2 whitespace-nowrap font-display text-lg font-extrabold uppercase tracking-[0.12em] no-underline sm:text-xl"
    >
      <span class="logo-dot"></span>
      <span class="grad-text">isaac</span><span class="logo-tail">perera</span>
    </a>

    <!-- Desktop nav -->
    <nav
      id="nav-menu"
      class="hidden items-center gap-x-1 font-display text-xs font-medium uppercase tracking-widest sm:flex"
    >
      <a
        href="/posts/"
        class={`nav-link ${activeNav === "posts" ? "nav-active" : ""}`}
      >
        Posts
      </a>
      <a
        href="/tags/"
        class={`nav-link ${activeNav === "tags" ? "nav-active" : ""}`}
      >
        Tags
      </a>
      <a
        href="/about/"
        class={`nav-link ${activeNav === "about" ? "nav-active" : ""}`}
      >
        About
      </a>

      <!-- Search -->
      <LinkButton
        href="/search/"
        className={`nav-link p-2 ${activeNav === "search" ? "nav-active" : ""}`}
        ariaLabel="search"
        title="Search"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <span class="sr-only">Search</span>
      </LinkButton>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="sm:hidden p-2"
      aria-label="Open Menu"
      aria-expanded="false"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="menu-icon"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="menu-items"
    class="header-bar mx-auto mt-2 hidden max-w-3xl rounded-2xl border px-4 sm:hidden"
  >
    <div
      class="flex flex-col py-2 font-display text-xs uppercase tracking-widest"
    >
      <a
        href="/posts/"
        class={`mob-link ${activeNav === "posts" ? "nav-active" : ""}`}>Posts</a
      >
      <a
        href="/tags/"
        class={`mob-link ${activeNav === "tags" ? "nav-active" : ""}`}>Tags</a
      >
      <a
        href="/about/"
        class={`mob-link ${activeNav === "about" ? "nav-active" : ""}`}>About</a
      >
      <a href="/search/" class="mob-link">Search</a>
    </div>
  </div>
</header>

<style>
  @reference "tailwindcss";

  .header-bar {
    background: color-mix(in srgb, var(--bg-2) 70%, transparent);
    border-color: var(--panel-border);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    box-shadow:
      0 1px 0 0 var(--line) inset,
      0 14px 40px -28px rgba(0, 0, 0, 0.7);
  }

  #skip-to-content {
    @apply absolute -top-full left-16 z-50 rounded-md px-3 py-2 text-xs uppercase tracking-widest text-[#04121a] transition-all focus:top-4;
    font-family: var(--font-display);
    background: var(--accent);
  }

  .logo-dot {
    @apply h-2.5 w-2.5 rounded-full;
    background: var(--accent);
    box-shadow:
      0 0 12px var(--accent),
      0 0 4px var(--accent);
    animation: pulse-dot 2.4s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.55;
      transform: scale(0.82);
    }
  }
  .logo-tail {
    color: var(--ink);
    opacity: 0.85;
  }

  .nav-link {
    @apply rounded-lg px-3 py-1.5 transition;
    color: var(--ink-soft);
  }
  .nav-link:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .nav-active {
    color: var(--accent);
    text-shadow: 0 0 14px var(--glow-a);
  }

  .mob-link {
    @apply border-t py-3 transition;
    border-color: var(--line);
    color: var(--ink-soft);
  }
  .mob-link:hover {
    color: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-dot {
      animation: none;
    }
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menuItems = document.getElementById("menu-items");

    if (!menuBtn || !menuItems) return;

    menuBtn.addEventListener("click", () => {
      const isHidden = menuItems.classList.contains("hidden");
      menuItems.classList.toggle("hidden", !isHidden);
      menuBtn.setAttribute("aria-expanded", isHidden ? "true" : "false");
    });
  }

  toggleNav();

  document.addEventListener("astro:after-swap", toggleNav);
</script>
