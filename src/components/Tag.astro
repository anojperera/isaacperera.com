---
export interface Props {
  tag: string;
  size?: "sm" | "lg";
}

const { tag, size = "sm" } = Astro.props;

// Channel accent per tag family (uses runtime theme vars)
function getTagColor(t: string) {
  const lower = t.toLowerCase();
  if (
    lower.includes("violin") ||
    lower.includes("string") ||
    lower.includes("concert")
  )
    return "var(--accent-2)";
  if (
    lower.includes("science") ||
    lower.includes("matter") ||
    lower.includes("project")
  )
    return "var(--accent-3)";
  return "var(--accent)"; // swimming / default
}
const color = getTagColor(tag);
---

<li class={`inline-block ${size === "lg" ? "my-1.5 mx-0.5" : "my-1"}`}>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class={`tag-pill hover:-translate-y-0.5 active:scale-95 ${size === "lg" ? "text-sm px-3.5 py-1.5" : ""}`}
    style={`--c:${color}; color:var(--c); border-color:color-mix(in srgb, var(--c) 45%, transparent); background:color-mix(in srgb, var(--c) 12%, transparent);`}
  >
    #{tag}
  </a>
</li>
