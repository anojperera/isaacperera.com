---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main id="main-content" class="flex-1 flex items-center justify-center">
    <div class="reveal py-12 text-center">
      <p class="kicker mb-3">⚠ signal lost</p>
      <div
        class="grad-text mb-2 font-display text-8xl font-black tracking-tight"
      >
        404
      </div>
      <p class="mb-2 font-display text-2xl font-bold uppercase tracking-wider">
        Page not found
      </p>
      <p class="mb-8 text-[color:var(--ink-soft)]">
        Looks like this one swam off course.
      </p>
      <a href="/" class="cool-button">Take me home</a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @reference "tailwindcss";
</style>
